{
  "homeAirport":"MMSM",
  "timezone": "UTC",
  "id":"DCCSELOPEZS553",
  "name": "ControllerName",
  "server.url":"https://ams-prd-haproxy.nlu.mx/",
  "server.offlineUrl": "${offline_server_url}",
  "server.currentUrl": "${server.url}",
  "data.poll.timeout": "30000",
  "data.poll.attempts": "3",
  "data.poll.interval": "5000",
  "data.poll.error.fallback": "1000",
  "data.poll.error.maxfallback": "3000",
  "data.poll.error.limit": "5",
  "data.poll.urls": "/fids/ng/cli/data/",
  "data.poll.failoverUrl": "/fids/ng/cli/data/",
  "data.poll.errorcodes": "404,500,401",
  "data.poll.successcodes": "200,304,202,204",
  "window.properties": "data.poll.error.limit,campaign.log.timeout,homeAirport,timezone,id,name,data.poll.errorcodes,data.poll.successcodes,data.poll.error.fallback,data.poll.error.maxfallback,data.poll.interval,data.poll.timeout,data.poll.attempts,data.poll.urls,data.poll.failoverUrl",
  "main.switches.0.key": "high-dpi-support",
  "main.switches.0.value": "1",
  "main.switches.1.key": "force-device-scale-factor",
  "main.switches.1.value": "1",
  "http.timeout": "500",
  "jobs.names": "",
  "jobs.CollectMetrics.cronRule": "*/10 * * * * *",
  "jobs.CollectMetrics.jobType": "RunCronRule",
  "jobs.CollectMetrics.metrics": "Memory,CPU_Usage,Top_Memory_Processes,Top_CPU_Processes,Temperature",
  "jobs.CollectMetrics.className": "CollectSystemInformation",
  "jobs.CollectMetrics.Top_Memory_Processes": "3",
  "jobs.CollectMetrics.Top_CPU_Processes": "3",
  "jobs.CollectMetrics2.cronRule": "*/10 * * * * *",
  "jobs.CollectMetrics2.jobType": "RunCronRule",
  "jobs.CollectMetrics2.metrics": "DiskUsage",
  "jobs.CollectMetrics2.className": "CollectCommandResults",
  "jobs.CollectMetrics2.DiskUsage.windowsCommand": "(Get-ChildItem . -Recurse | Measure-Object -Property Length -Sum -ErrorAction Stop).Sum",
  "jobs.CollectMetrics2.DiskUsage.linuxCommand": "du -s – *",
  "jobs.CollectMetrics2.DiskUsage.powerShell": "true",
  "http.timeout.job1": "4000",
  "http.timeout.job2": "8000",
  "http.timeouts": "2000",
  "http.urls": "defaultLayout/OpsWallLayout.html",
  "http.interval": "10000",
  "http.urls.CommandListener.primary": "${server.url}/fids/ng/cmd",
  "http.urls.failover.CommandListener.primary": "${server.url}/fids/ng/cmd",
  "http.timeouts.CommandListener.primary": "30000",
  "http.interval.CommandListener.primary": "500",
  "http.error.interval.CommandListener.primary": "30000",
  "http.urls.CommandListener.offline": "${server.offlineUrl}/fids/ng/cmd",
  "http.urls.failover.CommandListener.offline": "${server.offlineUrl}/fids/ng/cmd",
  "http.timeouts.CommandListener.offline": "30000",
  "http.interval.CommandListener.offline": "500",
  "http.error.interval.CommandListener.offline": "30000",
  "http.urls.ConfigFetch": "${server.url}/fids/ng/props?hopo=${homeAirport}&id=${id}",
  "http.timeouts.ConfigFetch": "2000",
  "processes.CommandProcess.environment": "electron",
  "processes.CommandProcess.processName": "CommandProcess",
  "processes.CommandProcess.moduleName": "CommandProcess.js",
  "processes.CommandProcess.messages": "logMessage,loadConfig",
  "processes.CommandProcess.arguments": "--high-dpi-support=1, --force-device-scale-factor=1, --fids-enable-web-security",
  "processes.CommandProcess.deferLogging": "false",
  "processes.names": "CommandProcess",
  "logger.filename": "controller",
  "logger.timestampFormat": "YYYY/MM/DD HH:mm:ss.SSSS",
  "logger.format": "${timestamp} | ${clientId} | ${level} | ${pid} | ${processName} | ${module} | ${correlationId} | ${message}",
  "logger.file.lowestLevel": "INFO",
  "logger.console.lowestLevel": "ERROR",
  "logger.maxSize": "50000000",
  "logger.maxFiles": "10",
  "restartAllProcess": "true",
  "health.rules": "showRule,windowStuck,killAllProcesses",
  "showRule.interval": "10000",
  "showRule.rule": "HealthRule IS \"SHOW_HOLD\" WHEN (($state != \"READY\") AND ($state !=\"CONFIG_RECEIVED\")) IS \"HIDE_HOLD\" WHEN ((($state == \"READY\") OR ($state == \"CONFIG_RECEIVED\")) AND ($dataState == \"REGISTERED\"))",
  "showRule.type": "Web",
  "windowFrozen.interval": "60000",
  "windowFrozen.rule": "HealthRule IS \"RESTART_WEB_COMPONENT\" WHEN ((NOW - TODATE($readings.dataState.0.timestamp)) > 1210000)",
  "windowFrozen.type": "Web",
  "windowStuck.interval": "60000",
  "windowStuck.rule": "HealthRule IS \"RESTART_WEB_COMPONENT\" WHEN (($state == \"ACTIVE\") AND ((NOW - TODATE($readings.state.0.timestamp)) > 35000))",
  "windowStuck.type": "Web",
  "memoryWarn.interval": "10000",
  "memoryWarn.rule": "HealthRule IS \"SEEK_HELP\" WHEN (${Memory.value} > TONUMBER(${Memory.memoryWarn.threshold}))",
  "memoryWarn.type": "Command",
  "killAllProcesses.interval": "5000",
  "killAllProcesses.rule": "HealthRule IS \"KILL_ALL_PROCESSES\" WHEN ($state == \"KILL_ALL_PROCESSES\")",
  "killAllProcesses.type": "Manual",
  "Memory.value": "$readings.Memory.0.value.used",
  "Memory.memoryWarn.threshold": "1",
  "diskWarn.interval": "10000",
  "diskWarn.rule": "HealthRule IS \"SEEK_HELP\" WHEN (${Disk.value} > TONUMBER(${Disk.diskWarn.threshold}))",
  "diskWarn.type": "Command",
  "Disk.value": "$readings.DiskUsage.0.value.stdout",
  "Disk.diskWarn.threshold": "10000000000",
  "CPUWarn.interval": "10000",
  "CPUWarn.rule": "HealthRule IS \"SEEK_HELP\" WHEN (${CPU.value} > TONUMBER(${CPU.CPUWarn.threshold}))",
  "CPUWarn.type": "Command",
  "CPU.value": "$readings.CPU_Usage.0.value",
  "CPU.CPUWarn.threshold": "1",
  "tempWarn.interval": "10000",
  "tempWarn.rule": "HealthRule IS \"SEEK_HELP\" WHEN (${Temperature.value} > TONUMBER(${Temperature.tempWarn.threshold}))",
  "tempWarn.type": "Command",
  "Temperature.value": "$readings.Temperature.0.value",
  "Temperature.tempWarn.threshold": "0",
  "logger.deferLogging": "false",
  "logger.serverTransports": "module,event,ad,metric",
  "module.http.url": "${server.currentUrl}/fids/ng/log/",
  "module.logger.type": "logs",
  "module.logger.defragCount": "300",
  "module.http.sendInterval": "10000",
  "module.http.maxObjects": "250",
  "module.http.maxSendSize": "2048",
  "module.http.timeout": "2000",
  "event.http.url": "${server.currentUrl}/fids/ng/log/",
  "event.logger.type": "events",
  "event.logger.defragCount": "300",
  "event.http.sendInterval": "10000",
  "event.http.maxObjects": "250",
  "event.http.maxSendSize": "2048",
  "event.http.timeout": "2000",
  "ad.http.url": "${server.currentUrl}/fids/ng/log/",
  "ad.logger.type": "ads",
  "ad.logger.defragCount": "300",
  "ad.http.sendInterval": "10000",
  "ad.http.maxObjects": "250",
  "ad.http.maxSendSize": "2048",
  "ad.http.timeout": "2000",
  "monitor.http.url": "${server.currentUrl}/fids/ng/layout?id=${id}&monitorId=${monitorName}&hopo=${homeAirport}&deviceType=NG&version=1.0.0",
  "metric.http.url": "${server.currentUrl}/fids/ng/log/",
  "metrics.maxLoggedActions": "5",
  "metric.logger.type": "metrics",
  "metric.logger.defragCount": "1000",
  "metric.http.sendInterval": "60000",
  "metric.http.maxObjects": "250",
  "metric.http.maxSendSize": "2048",
  "metric.http.timeout": "2000",
  "media.directory": "media",
  "media.server.url": "${server.url}/fids/ng/media/",
  "media.retry.interval": "30000",
  "media.offline.fail.refetch.delay.sec": "1200",
  "layout.timeout": "15000",
  "campaign.log.timeout":"900",
  "customer.id": "AITA-NLU",
  "globalShortcutsWindows.metrics": "KILL_ALL_PROCESSES",
  "KILL_ALL_PROCESSES.keys": "ctrl + x",
  "heartbeat.interval": "60000",
  "heartbeat.hold.interval": "60000",
  "crashFix.interval": "60000",
  "crashFix.rule": "HealthRule IS \"RESTART_WEB_COMPONENT\" WHEN (($lastHeartbeat IS SET) AND (TODATE($lastHeartbeat) < (NOW - 1)))",
  "crashFix.type": "Web",
  "crashNotify.interval": "60000",
  "crashNotify.rule": "HealthRule IS \"SEEK_HELP\" WHEN (($lastHeartbeat IS SET) AND (TODATE($lastHeartbeat) < (NOW - 1)))",
  "crashNotify.type": "Web",
  "offline.mode.active": "false"
}
